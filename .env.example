# =============================================================================
# ParcelIQ — Root .env (shared infrastructure values)
# Used by Docker Compose and Makefile. Copy to .env and fill in.
# For K8s deploy, this file is also the source for `make k8s-secrets`.
# =============================================================================

# ── PostgreSQL + PostGIS ─────────────────────────────────────────────────────
POSTGRES_USER=parceliq
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=parceliq
POSTGRES_PORT=5432

# K8s-required DB URLs:
# - DATABASE_URL: asyncpg (FastAPI services)
# - DATABASE_URL_SYNC: psycopg2 (Celery workers + migrations)
# For local Docker Compose/dev, localhost is typical.
# For K8s deploy, switch host to `postgres` before running `make deploy`.
DATABASE_URL=postgresql+asyncpg://parceliq:devpassword@localhost:5432/parceliq
DATABASE_URL_SYNC=postgresql+psycopg2://parceliq:devpassword@localhost:5432/parceliq

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# K8s secret keys expected by services (can match ROOT values if desired)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
REPORT_PDF_BUCKET=property-report-pdfs

# ── Flower (Celery monitor) ─────────────────────────────────────────────────
FLOWER_PORT=5555
# ── pgAdmin (PostgreSQL web management) ──────────────────────────────────────
PGADMIN_PASSWORD=devpassword

# ── Clerk — Public Instance (public-web + public-api) ───────────────────────
CLERK_PUBLIC_PUBLISHABLE_KEY=<PLACEHOLDER>
CLERK_PUBLIC_SECRET_KEY=<PLACEHOLDER>
CLERK_PUBLIC_JWKS_URL=<PLACEHOLDER>

# ── Clerk — Admin Instance (admin-web + admin-backend) ──────────────────────
CLERK_ADMIN_PUBLISHABLE_KEY=<PLACEHOLDER>
CLERK_ADMIN_SECRET_KEY=<PLACEHOLDER>
CLERK_ADMIN_ORG_ID=<PLACEHOLDER>

# ── Internal service auth ────────────────────────────────────────────────────
ADMIN_SERVICE_TOKEN=<PLACEHOLDER>
INTERNAL_WEBHOOK_SECRET=<PLACEHOLDER>

# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
TURNSTILE_SECRET_KEY=<PLACEHOLDER>

# ── Stripe (credit purchase payments — services/public-api) ──────────────────
STRIPE_SECRET_KEY=<PLACEHOLDER>
STRIPE_WEBHOOK_SECRET=<PLACEHOLDER>
# STRIPE_UNIT_PRICE_AUD_CENTS=100         # Optional non-secret tuning
# STRIPE_MIN_CREDITS=5                    # Optional non-secret tuning

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=<PLACEHOLDER>

# ── OpenAI (llm-parser-worker) ───────────────────────────────────────────────
OPENAI_API_KEY=<PLACEHOLDER>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_DAILY_QUOTA=100000
OPENAI_MAX_RPM=60

# ── Residential proxy (scraper-worker) ───────────────────────────────────────
PROXY_URL=<PLACEHOLDER>
PROXY_USERNAME=<PLACEHOLDER>
PROXY_PASSWORD=<PLACEHOLDER>

# ── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Property Image Enrichment ──────────────────────────────────────────────────
PROPERTY_IMAGE_ENRICHMENT_ENABLED=true
GOOGLE_MAPS_API_KEY=<PLACEHOLDER>
PROPERTY_IMAGE_REQUEST_TIMEOUT_SECONDS=4.0
