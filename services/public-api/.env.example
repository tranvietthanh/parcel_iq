# =============================================================================
# services/public-api — Environment Variables
# Copy to .env and fill in values.
# =============================================================================

# ── Database (asyncpg — async driver) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://parceliq:devpassword@localhost:5432/parceliq

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Clerk — Public Instance JWKS ─────────────────────────────────────────────
CLERK_PUBLIC_JWKS_URL=https://<your-clerk-public-instance>.clerk.accounts.dev/.well-known/jwks.json

# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Test secret below always passes — no real verification in dev
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Internal Webhook Secret ──────────────────────────────────────────────────
# Must match the value in apps/public-web/.env.local
INTERNAL_WEBHOOK_SECRET=dev-webhook-secret-change-in-prod

# ── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Feature Flags ────────────────────────────────────────────────────────
# Set to true to enable credit purchasing via Stripe
CREDIT_PURCHASE_ENABLED=false

# ── MinIO (PDF Storage) ──────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
REPORT_PDF_BUCKET=property-reports
