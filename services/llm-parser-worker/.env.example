# =============================================================================
# services/llm-parser-worker — Environment Variables
# Copy to .env and fill in values.
# =============================================================================

# ── Database (psycopg2 — sync driver, Celery workers are sync) ───────────────
DATABASE_URL=postgresql+psycopg2://parceliq:devpassword@localhost:5432/parceliq

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (standard) ───────────────────────────────────────────────────────
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
OPENAI_DAILY_QUOTA=100000
OPENAI_MAX_RPM=60

# ── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
