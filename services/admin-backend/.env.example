# =============================================================================
# services/admin-backend — Environment Variables
# Copy to .env and fill in values.
# =============================================================================

# ── Database (asyncpg — async driver) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://parceliq:devpassword@localhost:5432/parceliq

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Service Token ────────────────────────────────────────────────────────────
# Must match the value in apps/admin-web/.env.local
ADMIN_SERVICE_TOKEN=dev-service-token-change-in-prod

# ── Flower ───────────────────────────────────────────────────────────────────
FLOWER_INTERNAL_URL=http://localhost:5555

# ── MinIO (PDF report cache) ────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
REPORT_PDF_BUCKET=property-report-pdfs

# ── Property Image Enrichment (optional) ───────────────────────────────────
# Enable satellite aerial + Street View images in generated PDFs
PROPERTY_IMAGE_ENRICHMENT_ENABLED=false

# Google Maps API key — used for both Maps Static (satellite cover) and Street View Static APIs
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Required APIs: Maps Static API, Street View Static API
GOOGLE_MAPS_API_KEY=

# ── LLM Quota (llm-parser-worker OpenAI settings) ───────────────────────────
# Configure OPENAI_DAILY_QUOTA in services/llm-parser-worker/.env
OPENAI_DAILY_QUOTA=100000

# ── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
