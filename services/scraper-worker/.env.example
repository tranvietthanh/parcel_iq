# =============================================================================
# services/scraper-worker — Environment Variables
# Copy to .env and fill in values.
# =============================================================================

# ── Database (psycopg2 — sync driver, Celery workers are sync) ───────────────
DATABASE_URL=postgresql+psycopg2://parceliq:devpassword@localhost:5432/parceliq

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ── Residential Proxy ────────────────────────────────────────────────────────
# Not needed for local dev — adapters that need it will skip gracefully
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# ── Worker Config ────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=1
VICPLAN_CACHE_TTL_HOURS=168

# ── App Config ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
